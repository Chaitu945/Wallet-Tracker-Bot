# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here

# Moralis (get a free key at https://moralis.com — one key covers EVM + Solana)
MORALIS_API_KEY=your_moralis_api_key_here

# How often (in minutes) to poll each tracked wallet for new activity
POLL_INTERVAL_MINUTES=2

# A token is flagged as a "fresh ape" if its liquidity pool is younger than this (minutes)
NEW_TOKEN_AGE_THRESHOLD_MINUTES=1440

# Robinhood Chain — optional. Uses Blockscout's free public API by default (no key needed).
# Only set this if you want to point at a different Blockscout instance.
# ROBINHOOD_BLOCKSCOUT_API=https://robinhoodchain.blockscout.com/api
